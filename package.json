{
  "name": "excel-to-sql-migrator",
  "version": "1.0.0",
  "description": "Migrador profesional de bases de datos Excel a SQL (MySQL, PostgreSQL, SQL Server)",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev": "npm run build:main && electron .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.exsql.migrator",
    "productName": "ExSQL Migrator",
    "files": [
      "dist/**/*",
      "src/renderer/**/*.html",
      "src/renderer/**/*.css",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "knex": "^3.1.0",
    "mysql2": "^3.9.0",
    "pg": "^8.12.0",
    "tedious": "^18.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.0"
  },
  "author": "Carlos - ExSQL",
  "license": "MIT"
}
